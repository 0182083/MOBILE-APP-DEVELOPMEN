<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Category Tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@+id/categoryLayout"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <Button android:id="@+id/btnAll" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="All"/>
            <Button android:id="@+id/btnNature" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nature"/>
            <Button android:id="@+id/btnCity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="City"/>
            <Button android:id="@+id/btnAnimals" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Animals"/>
            <Button android:id="@+id/btnFood" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Food"/>
            <Button android:id="@+id/btnTravel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Travel"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Selection Toolbar -->
    <LinearLayout
        android:id="@+id/selectionBar"
        android:visibility="gone"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txtSelected"
            android:text="0 selected"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete"/>
    </LinearLayout>

    <!-- GridView -->
    <GridView
        android:id="@+id/gridView"
        android:numColumns="2"
        android:verticalSpacing="8dp"
        android:horizontalSpacing="8dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
